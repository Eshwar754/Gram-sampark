rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == "admin";
    }

    function isSurveyor() {
      return isSignedIn() && (userDoc().data.role == "surveyor" || (userDoc().data.role == "user" && userDoc().data.status == "approved"));
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    // VILLAGES
    match /villages/{villageId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // PATIENTS (STRICT CONTROL)
    match /residents/{residentId} {

      // Admin full access
      allow read, write, delete: if isAdmin();

      // Surveyor only for assigned village
      allow read: if isSurveyor();

      allow create: if isSurveyor()
        && request.resource.data.village_id != null
        && (request.auth.uid in get(/databases/$(database)/documents/villages/$(request.resource.data.village_id)).data.assigned_users
            || request.auth.token.email in get(/databases/$(database)/documents/villages/$(request.resource.data.village_id)).data.assigned_users);

      allow update: if isSurveyor()
        && (
          !('village_id' in resource.data) 
          || resource.data.village_id == null 
          || resource.data.village_id == ""
          || (
              exists(/databases/$(database)/documents/villages/$(resource.data.village_id)) 
              && (
                 request.auth.uid in get(/databases/$(database)/documents/villages/$(resource.data.village_id)).data.assigned_users
                 || request.auth.token.email in get(/databases/$(database)/documents/villages/$(resource.data.village_id)).data.assigned_users
              )
             )
        );

      // Surveyor can delete from their assigned village or if village is missing/invalid
      allow delete: if isSurveyor()
        && (
          !('village_id' in resource.data) 
          || resource.data.village_id == null 
          || resource.data.village_id == ""
          || (
              exists(/databases/$(database)/documents/villages/$(resource.data.village_id)) 
              && (
                 request.auth.uid in get(/databases/$(database)/documents/villages/$(resource.data.village_id)).data.assigned_users
                 || request.auth.token.email in get(/databases/$(database)/documents/villages/$(resource.data.village_id)).data.assigned_users
              )
             )
        );
    }

    // DECEASED RECORDS
    match /deceased_records/{recordId} {
      allow read, write: if isAdmin() || isSurveyor();
    }

    // ACCESS REQUESTS
    match /access_requests/{requestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // SCHEMES
    match /schemes/{schemeId} {
      allow read: if isAdmin() || isSurveyor();
      allow create, update, delete: if isAdmin();
    }

    // BENEFICIARIES
    match /beneficiaries/{id} {

      allow read: if isAdmin() || isSurveyor();

      // Admin full control
      allow write, delete: if isAdmin();

      // Surveyor limited control
      allow create: if isSurveyor()
        && (request.resource.data.assignedSurveyorId == request.auth.uid || request.resource.data.assignedSurveyorEmail == request.auth.token.email);

      allow update: if isSurveyor()
        && (
            (resource.data.assignedSurveyorId == request.auth.uid || resource.data.assignedSurveyorEmail == request.auth.token.email) ||
            (resource.data.citizenVillageId != null && 
              (request.auth.uid in get(/databases/$(database)/documents/villages/$(resource.data.citizenVillageId)).data.assigned_users || 
               request.auth.token.email in get(/databases/$(database)/documents/villages/$(resource.data.citizenVillageId)).data.assigned_users)
            )
           );

      allow delete: if isSurveyor()
        && (
            (resource.data.assignedSurveyorId == request.auth.uid || resource.data.assignedSurveyorEmail == request.auth.token.email) ||
            (resource.data.citizenVillageId != null && 
              (request.auth.uid in get(/databases/$(database)/documents/villages/$(resource.data.citizenVillageId)).data.assigned_users || 
               request.auth.token.email in get(/databases/$(database)/documents/villages/$(resource.data.citizenVillageId)).data.assigned_users)
            )
           );
    }

  }
}